<section class="action-attributes">
  <h3 class="section-heading">Attributes</h3>
  <div class="attributes-grid">
    {{#each attributes}}
    <div class="attribute-cell">
      <div class="attribute-label">{{label}}</div>
      <button type="button" class="attr-value view-only" data-action="rollAttribute" data-attribute="{{key}}" title="Roll {{label}}">{{value}}</button>
      <input type="number" class="attr-value-input edit-only" data-attribute-key="{{key}}" value="{{value}}" min="0" max="10" />
    </div>
    {{/each}}
  </div>
</section>

<section class="action-skills">
  <div class="section-heading-row">
    <h3 class="section-heading">Skills</h3>
    <button type="button" class="add-skill-btn edit-only" data-action="addSkill" title="Add skill">+</button>
  </div>
  {{#if skills.length}}
    {{#each skills}}
    <div class="skill-group">
      <h4 class="skill-group-heading">{{attributeLabel}}</h4>
      <ul class="skill-list">
        {{#each skills}}
        <li class="skill-row">
          <span class="skill-name">{{name}}</span>
          <span class="skill-rank view-only">Rank {{rank}}</span>
          <input type="number" class="skill-rank-input edit-only" data-item-id="{{id}}" value="{{rank}}" min="0" max="10" />
          <span class="skill-mod">Mod {{rollModifier}}</span>
          <button type="button" class="skill-roll-btn view-only" data-action="rollSkill" data-item-id="{{id}}">Roll</button>
          <button type="button" class="skill-edit-btn edit-only" data-action="openItem" data-item-id="{{id}}" title="Edit skill">✎</button>
          <button type="button" class="skill-delete-btn edit-only" data-action="deleteSkill" data-item-id="{{id}}" title="Delete skill">×</button>
        </li>
        {{/each}}
      </ul>
    </div>
    {{/each}}
  {{else}}
    <p class="empty-state">No skills on this hero yet.</p>
  {{/if}}
</section>
