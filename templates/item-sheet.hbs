<div class="item-sheet-inner">
  <header class="item-header">
    <img class="item-img" src="{{item.img}}" alt="" />
    <div class="item-header-main">
      <h2 class="item-name-display view-only">{{item.name}}</h2>
      <input class="item-name-input edit-only" type="text" data-field="name" value="{{item.name}}" placeholder="Item name" />
      <span class="item-type-tag">{{item.type}}</span>
    </div>
  </header>

  <div class="item-body">

    {{#if isSkill}}
    <div class="item-field-row">
      <label class="item-field-label">Attribute</label>
      <span class="item-field-value view-only">{{attributeLabel}}</span>
      <select class="item-field-value edit-only" data-field="system.attribute">
        {{#each attributeOptions}}
        <option value="{{value}}" {{#if (eq ../attribute value)}}selected{{/if}}>{{label}}</option>
        {{/each}}
      </select>
    </div>
    <div class="item-field-row">
      <label class="item-field-label">Rank</label>
      <span class="item-field-value view-only">{{rank}}</span>
      <input class="item-field-value item-rank-input edit-only" type="number" data-field="system.rank" value="{{rank}}" min="0" max="10" />
    </div>
    {{/if}}

    {{#if isTalent}}
    <div class="item-field-row">
      <label class="item-field-label">Tree</label>
      <span class="item-field-value view-only">{{treeName}}</span>
      <input class="item-field-value edit-only" type="text" data-field="flags.veilrunner.talent.treeName" value="{{treeName}}" placeholder="Tree name" />
    </div>
    <div class="item-field-row">
      <label class="item-field-label">Tier</label>
      <span class="item-field-value view-only">{{tier}}</span>
      <input class="item-field-value item-rank-input edit-only" type="number" data-field="flags.veilrunner.talent.tier" value="{{tier}}" min="0" max="5" />
    </div>
    <div class="item-field-row">
      <label class="item-field-label">Unlocked</label>
      <span class="item-field-value view-only">{{#if unlocked}}Yes{{else}}No{{/if}}</span>
      <input type="checkbox" class="edit-only" data-field="flags.veilrunner.talent.unlocked" {{#if unlocked}}checked{{/if}} />
    </div>
    {{/if}}

    <div class="item-field-row item-field-row--description">
      <label class="item-field-label">Description</label>
      <p class="item-field-value item-description-text view-only">{{description}}</p>
      <textarea class="item-field-value item-description edit-only" data-field="system.description" rows="4">{{description}}</textarea>
    </div>

  </div>
</div>
